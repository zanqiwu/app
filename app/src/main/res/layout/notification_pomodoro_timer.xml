<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pomodoro_notification_card"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:background="@drawable/notification_pomodoro_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <View
        android:layout_width="5dp"
        android:layout_height="match_parent"
        android:background="@drawable/notification_pomodoro_accent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="10dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/pomodoro_notification_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:text="番茄钟专注中"
            android:textColor="@color/pomodoro_text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/pomodoro_notification_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:background="@drawable/notification_pomodoro_pill"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingStart="9dp"
            android:paddingTop="3dp"
            android:paddingEnd="9dp"
            android:paddingBottom="3dp"
            android:text="锁屏倒计时"
            android:textColor="@color/pomodoro_primary"
            android:textSize="11sp" />
    </LinearLayout>

    <Chronometer
        android:id="@+id/pomodoro_notification_time"
        android:layout_width="112dp"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:gravity="end|center_vertical"
        android:singleLine="true"
        android:textColor="@color/pomodoro_primary"
        android:textSize="27sp"
        android:textStyle="bold" />
</LinearLayout>
