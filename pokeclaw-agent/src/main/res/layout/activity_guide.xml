<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgPrimary">

    <!-- 跳过按钮 -->
    <TextView
        android:id="@+id/tvSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="@string/guide_skip"
        android:textColor="@color/colorTextTertiary"
        android:textSize="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 可滚动内容 -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tvSkip"
        app:layout_constraintBottom_toTopOf="@id/btnStart">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- 页面标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guide_page_title"
                android:textColor="@color/colorTextPrimary"
                android:textSize="24dp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/guide_page_subtitle"
                android:textColor="@color/colorTextSecondary"
                android:textSize="14dp" />

            <!-- 1. 无障碍服务 -->
            <include
                android:id="@+id/guideAccessibility"
                layout="@layout/item_guide_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp" />

            <!-- 2. 常驻通知 -->
            <include
                android:id="@+id/guideNotification"
                layout="@layout/item_guide_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp" />

            <!-- 3. 悬浮窗 -->
            <include
                android:id="@+id/guideOverlay"
                layout="@layout/item_guide_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp" />

            <!-- 4. 电池白名单 -->
            <include
                android:id="@+id/guideBattery"
                layout="@layout/item_guide_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp" />

            <!-- 5. 文件访问 -->
            <include
                android:id="@+id/guideStorage"
                layout="@layout/item_guide_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- 开始使用按钮 -->
    <io.agents.pokeclaw.widget.KButton
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="48dp"
        android:text="@string/guide_start"
        android:textSize="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
