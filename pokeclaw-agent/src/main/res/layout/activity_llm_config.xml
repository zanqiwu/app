<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgSecondary"
    android:orientation="vertical">

    <io.agents.pokeclaw.widget.CommonToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp" />

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:isScrollContainer="true"
        android:fillViewport="true"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Active Model Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4dp"
                android:paddingBottom="8dp"
                android:text="Active Model"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13dp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_avatar_ai"
                        android:gravity="center"
                        android:text="🦞"
                        android:textSize="22dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvActiveModelName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No model"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="15dp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvActiveModelMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Tap to download a model"
                            android:textColor="@color/colorTextTertiary"
                            android:textSize="12dp" />

                        <TextView
                            android:id="@+id/tvActiveModelStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="● Not configured"
                            android:textColor="@color/colorSuccessPrimary"
                            android:textSize="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="4dp"
                android:paddingBottom="8dp"
                android:text="Default Models"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13dp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:gravity="center"
                            android:text="📱"
                            android:textSize="18dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Default local model"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="12dp" />

                            <TextView
                                android:id="@+id/tvDefaultLocalName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Not set"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14dp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDefaultLocalMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Choose a local model below"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="12dp" />

                            <TextView
                                android:id="@+id/tvDefaultLocalStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="● Not configured"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="12dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="14dp"
                        android:background="#1FFFFFFF" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:gravity="center"
                            android:text="☁️"
                            android:textSize="18dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Default cloud model"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="12dp" />

                            <TextView
                                android:id="@+id/tvDefaultCloudName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Not set"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14dp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDefaultCloudMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Configure a cloud model below"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="12dp" />

                            <TextView
                                android:id="@+id/tvDefaultCloudStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="● Not configured"
                                android:textColor="@color/colorTextTertiary"
                                android:textSize="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Available Models -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="4dp"
                android:paddingBottom="8dp"
                android:text="Available Models"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13dp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutModelList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Storage section hidden — not useful for end users -->
            <TextView
                android:id="@+id/tvStorageInfo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <ProgressBar
                android:id="@+id/progressStorage"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tvStorageDetail"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <!-- Cloud LLM -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="4dp"
                android:paddingBottom="8dp"
                android:text="Cloud LLM"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13dp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Provider Tabs -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:id="@+id/layoutProviderTabs"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_edit_text"
                            android:orientation="horizontal"
                            android:padding="3dp" />

                    </HorizontalScrollView>

                    <!-- Model List (programmatic) -->
                    <LinearLayout
                        android:id="@+id/layoutCloudModels"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- API Key -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="API Key"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etApiKey"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_edit_text"
                            android:hint="sk-..."
                            android:inputType="textPassword"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/colorTextPrimary"
                            android:textColorHint="@color/colorTextTertiary"
                            android:textSize="13dp" />

                        <TextView
                            android:id="@+id/btnClearApiKey"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:paddingHorizontal="10dp"
                            android:text="Clear"
                            android:textColor="@color/colorErrorPrimary"
                            android:textSize="12dp" />

                    </LinearLayout>

                    <!-- Base URL (Custom only) -->
                    <LinearLayout
                        android:id="@+id/layoutBaseUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Base URL"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="12dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/etBaseUrl"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edit_text"
                            android:hint="https://api.openrouter.ai/v1"
                            android:inputType="textUri"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/colorTextPrimary"
                            android:textColorHint="@color/colorTextTertiary"
                            android:textSize="13dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Model Name"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="12dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/etModelName"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_edit_text"
                            android:hint="google/gemini-2.5-flash"
                            android:inputType="text"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/colorTextPrimary"
                            android:textColorHint="@color/colorTextTertiary"
                            android:textSize="13dp" />

                    </LinearLayout>

                    <!-- Connection Status -->
                    <TextView
                        android:id="@+id/tvConnectionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="12dp"
                        android:visibility="gone" />

                    <!-- Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnTestConnection"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_edit_text"
                            android:gravity="center"
                            android:text="Test"
                            android:textColor="@color/colorBrandPrimary"
                            android:textSize="13dp" />

                        <io.agents.pokeclaw.widget.KButton
                            android:id="@+id/btnSaveCloud"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="2"
                            android:text="Save &amp; Activate" />

                    </LinearLayout>

                    <!-- Compatible endpoints hint (Custom only) -->
                    <TextView
                        android:id="@+id/tvCustomHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Compatible with: OpenRouter, Groq, Together AI, Ollama, any OpenAI-compatible endpoint"
                        android:textColor="@color/colorTextTertiary"
                        android:textSize="10dp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
