<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp">

    <!-- Theme preview card -->
    <LinearLayout
        android:id="@+id/cardPreview"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Fake chat bubbles -->
        <View
            android:id="@+id/previewUserBubble"
            android:layout_width="50dp"
            android:layout_height="14dp"
            android:layout_gravity="end"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical">

            <View
                android:id="@+id/previewAvatar"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="4dp" />

            <View
                android:id="@+id/previewAiBubble"
                android:layout_width="40dp"
                android:layout_height="14dp" />
        </LinearLayout>

        <View
            android:id="@+id/previewUserBubble2"
            android:layout_width="35dp"
            android:layout_height="14dp"
            android:layout_gravity="end"
            android:layout_marginBottom="4dp" />

        <!-- Fake input bar -->
        <View
            android:id="@+id/previewInputBar"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- Selected indicator -->
    <View
        android:id="@+id/selectedIndicator"
        android:layout_width="24dp"
        android:layout_height="3dp"
        android:layout_marginTop="6dp"
        android:visibility="invisible" />

    <!-- Theme name -->
    <TextView
        android:id="@+id/tvThemeName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:textColor="@color/colorTextSecondary"
        android:textSize="11dp" />
</LinearLayout>
